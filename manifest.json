{
  "manifest_version": 3,
  "name": "Teams Live Caption Capture",
  "version": "1.0",
  "description": "Capture and save live captions from Microsoft Teams meetings with timestamps",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://teams.microsoft.com/*",
    "https://teams.cloud.microsoft/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://teams.cloud.microsoft/*"
      ],
      "js": ["capture.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Teams Live Caption Capture"
  }
}